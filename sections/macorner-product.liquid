{{ 'section-main-product.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}
{{ 'macorner-clone.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'media-gallery.js' | asset_url }}" defer="defer"></script>

<div class="mac-container">
  <section
    id="MainProduct-{{ section.id }}"
    data-section="{{ section.id }}"
    class="product-info-macorner product product--large product--left product--thumbnail_slider product--mobile-show"
  >
    <div class="mac-product-grid">
      <!-- Cột Trái: Ảnh sản phẩm (Gallery) -->
      <div class="mac-product-media product__media-wrapper">
        {% assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src' %}
        {% render 'product-media-gallery', variant_images: variant_images %}
      </div>

      <!-- Cột Phải: Thông tin sản phẩm -->
      <div class="mac-product-info grid__item">
        <product-info
          id="ProductInfo-{{ section.id }}"
          data-section="{{ section.id }}"
          data-url="{{ product.url }}"
        >
          {%- assign product_form_id = 'product-form-' | append: section.id -%}
          
          <!-- Title -->
          <h1 class="mac-product-title">{{ product.title | escape }}</h1>

          <!-- Review Summary -->
          <div class="mac-review-summary">
            <div class="mac-stars">
              <svg viewBox="0 0 24 24" fill="#ed5b24" width="20" height="20"><path d="M12 17.27l-5.18 3.73 1.64-7.03L3 9.24l7.19-.61L12 2l1.81 6.63 7.19.61-5.46 4.73 1.64 7.03z"/></svg>
              <svg viewBox="0 0 24 24" fill="#ed5b24" width="20" height="20"><path d="M12 17.27l-5.18 3.73 1.64-7.03L3 9.24l7.19-.61L12 2l1.81 6.63 7.19.61-5.46 4.73 1.64 7.03z"/></svg>
              <svg viewBox="0 0 24 24" fill="#ed5b24" width="20" height="20"><path d="M12 17.27l-5.18 3.73 1.64-7.03L3 9.24l7.19-.61L12 2l1.81 6.63 7.19.61-5.46 4.73 1.64 7.03z"/></svg>
              <svg viewBox="0 0 24 24" fill="#ed5b24" width="20" height="20"><path d="M12 17.27l-5.18 3.73 1.64-7.03L3 9.24l7.19-.61L12 2l1.81 6.63 7.19.61-5.46 4.73 1.64 7.03z"/></svg>
              <svg viewBox="0 0 24 24" fill="#ed5b24" width="20" height="20"><path d="M12 17.27l-5.18 3.73 1.64-7.03L3 9.24l7.19-.61L12 2l1.81 6.63 7.19.61-5.46 4.73 1.64 7.03z"/></svg>
            </div>
            <a href="#reviews" class="mac-review-link">11 reviews</a>
          </div>
          <div class="mac-bought-past-month">6K+ bought in past month</div>

          <!-- Price -->
          <div class="mac-price-wrapper" id="price-{{ section.id }}">
            <span class="mac-price-regular">{{ product.selected_or_first_available_variant.price | money_with_currency }}</span>
            {% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}
              <span class="mac-price-compare">{{ product.selected_or_first_available_variant.compare_at_price | money_with_currency }}</span>
              {% assign saving = product.selected_or_first_available_variant.compare_at_price | minus: product.selected_or_first_available_variant.price | times: 100.0 | divided_by: product.selected_or_first_available_variant.compare_at_price | round %}
              <span class="mac-price-save-badge">Save {{ saving }}%</span>
            {% endif %}
          </div>

          <!-- Delivery -->
          <div class="mac-delivery-block">
             <div class="mac-deliver-item">
               <span class="mac-flag">🇺🇸</span>
               <span>Deliver to <a href="#">United States</a></span>
             </div>
             <div class="mac-deliver-item">
               <span class="mac-truck">🚚</span>
               <span>Get it by: <strong>March 17-23</strong></span>
             </div>
          </div>

          <!-- Hiển thị Variants động từ Shopify dạng Radio Button (Pill) -->
          {%- unless product.has_only_default_variant -%}
            <variant-selects
              id="variant-selects-{{ section.id }}"
              data-section="{{ section.id }}"
              data-url="{{ product.url }}"
            >
              {%- for option in product.options_with_values -%}
                <fieldset class="js product-form__input product-form__input--pill">
                  <legend class="form__label">{{ option.name }}</legend>
                  {% render 'product-variant-options',
                    product: product,
                    option: option,
                    block: section,
                    picker_type: 'button'
                  %}
                </fieldset>
              {%- endfor -%}
              <script type="application/json" data-selected-variant>
                {{ product.selected_or_first_available_variant | json }}
              </script>
            </variant-selects>
          {%- endunless -%}

          <!-- Box chứa nút Add to Cart -->
          <div class="mac-buy-buttons" style="margin-top: 20px;">
            {%- form 'product', product, id: product_form_id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
              <input 
                type="hidden" 
                name="id" 
                value="{{ product.selected_or_first_available_variant.id }}"
                {%- if product.selected_or_first_available_variant.available == false -%}
                  disabled
                {%- endif -%}
                class="product-variant-id"
              >

              <button type="submit" name="add" class="mac-btn-add" id="ProductSubmitButton-{{ section.id }}" {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}>
                <span class="text">
                  {% if product.selected_or_first_available_variant.available %}
                    ADD TO CART
                  {% else %}
                    SOLD OUT
                  {% endif %}
                </span>
                <div class="loading-overlay__spinner hidden">
                  <svg aria-hidden="true" focusable="false" class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg">
                    <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                  </svg>
                </div>
              </button>
            {%- endform -%}
          </div>

          <!-- Box chứa Accordion (Expanse) -->
          <div class="mac-product-accordions" style="margin-top: 2rem;">
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when 'collapsible_tab' -%}
                  <div class="product__accordion accordion quick-add-hidden" {{ block.shopify_attributes }}>
                    <details id="Details-{{ block.id }}-{{ section.id }}">
                      <summary>
                        <div class="summary__title">
                          <h2 class="h4 accordion__title inline-richtext">
                            {{ block.settings.heading | default: block.settings.page.title }}
                          </h2>
                        </div>
                        <svg aria-hidden="true" focusable="false" class="icon icon-caret" viewBox="0 0 10 6">
                          <path fill-rule="evenodd" clip-rule="evenodd" d="M9.354.646a.5.5 0 00-.708 0L5 4.293 1.354.646a.5.5 0 00-.708.708l4 4a.5.5 0 00.708 0l4-4a.5.5 0 000-.708z" fill="currentColor"></path>
                        </svg>
                      </summary>
                      <div class="accordion__content rte" id="ProductAccordion-{{ block.id }}-{{ section.id }}">
                        {%- if block.settings.heading == 'Description' or block.settings.heading == 'Mô tả' -%}
                          {{ product.description }}
                        {%- else -%}
                          {{ block.settings.content }}
                          {{ block.settings.page.content }}
                        {%- endif -%}
                      </div>
                    </details>
                  </div>
              {%- endcase -%}
            {%- endfor -%}
          </div>

          <!-- Thông báo đang có người xem / trong giỏ hàng -->
          <div class="mac-cart-watching" style="display: flex; align-items: center; gap: 8px; margin-top: 15px; color: #d32f2f; font-weight: 600; font-size: 1.4rem;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
              <circle cx="12" cy="12" r="3"></circle>
            </svg>
            <span><span class="random-cart-number">3</span> people have this item in their carts right now.</span>
          </div>

          <script>
            // Simple logic to randomize between 2-8 people
            document.addEventListener("DOMContentLoaded", () => {
              const numSpan = document.querySelector('.random-cart-number');
              if(numSpan) {
                numSpan.innerText = Math.floor(Math.random() * 7) + 2;
              }
            });
          </script>

        </product-info>
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Macorner Clean Product",
  "settings": [
    {
      "type": "select",
      "id": "picker_type",
      "options": [
        {
          "value": "dropdown",
          "label": "Dropdown"
        },
        {
          "value": "button",
          "label": "Pill"
        }
      ],
      "default": "button",
      "label": "Variant picker type"
    },
    {
      "type": "select",
      "id": "gallery_layout",
      "options": [
        {
          "value": "stacked",
          "label": "Stacked"
        },
        {
          "value": "thumbnail_slider",
          "label": "Thumbnail slider"
        }
      ],
      "default": "thumbnail_slider",
      "label": "Media Gallery Layout"
    },
    {
      "type": "select",
      "id": "media_size",
      "options": [
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "large",
          "label": "Large"
        }
      ],
      "default": "large",
      "label": "Media Size"
    },
    {
      "type": "select",
      "id": "media_position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left",
      "label": "Media Position"
    },
    {
      "type": "select",
      "id": "mobile_thumbnails",
      "options": [
        {
          "value": "show",
          "label": "Show"
        },
        {
          "value": "hide",
          "label": "Hide"
        },
        {
          "value": "columns",
          "label": "Columns"
        }
      ],
      "default": "show",
      "label": "Mobile Thumbnails"
    }
  ],
  "blocks": [
    {
      "type": "collapsible_tab",
      "name": "Collapsible row",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Collapsible row",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Row content"
        },
        {
          "type": "page",
          "id": "page",
          "label": "Row content from page"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Macorner Clean Product"
    }
  ]
}
{% endschema %}
