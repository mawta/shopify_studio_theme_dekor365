{{ 'section-main-product.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}
{{ 'macorner-clone.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'media-gallery.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign seconds_per_day = 86400
  assign shipping_min_days = section.settings.default_shipping_min_days
  assign shipping_max_days = section.settings.default_shipping_max_days
  assign matched_shipping_tag = blank

  for shipping_block in section.blocks
    if shipping_block.type == 'shipping_rule'
      assign rule_tag = shipping_block.settings.product_tag | strip | downcase

      if rule_tag != blank
        for product_tag in product.tags
          assign normalized_product_tag = product_tag | strip | downcase
          if normalized_product_tag == rule_tag
            assign shipping_min_days = shipping_block.settings.min_days
            assign shipping_max_days = shipping_block.settings.max_days
            assign matched_shipping_tag = product_tag
            break
          endif
        endfor
      endif
    endif

    if matched_shipping_tag != blank
      break
    endif
  endfor

  if shipping_max_days < shipping_min_days
    assign shipping_max_days = shipping_min_days
  endif

  assign now_timestamp = 'now' | date: '%s'
  assign delivery_min_timestamp = shipping_min_days | times: seconds_per_day | plus: now_timestamp
  assign delivery_max_timestamp = shipping_max_days | times: seconds_per_day | plus: now_timestamp
  assign delivery_min_month = delivery_min_timestamp | date: '%B'
  assign delivery_max_month = delivery_max_timestamp | date: '%B'
  assign delivery_min_day = delivery_min_timestamp | date: '%-d'
  assign delivery_max_day = delivery_max_timestamp | date: '%-d'

  if delivery_min_month == delivery_max_month
    assign delivery_window = delivery_min_month | append: ' ' | append: delivery_min_day | append: '-' | append: delivery_max_day
  else
    assign delivery_window = delivery_min_month | append: ' ' | append: delivery_min_day | append: ' - ' | append: delivery_max_month | append: ' ' | append: delivery_max_day
  endif
-%}

<div class="mac-container">
  <section
    id="MainProduct-{{ section.id }}"
    data-section="{{ section.id }}"
    class="product-info-macorner product product--large product--left product--thumbnail_slider product--mobile-show"
  >
    <div class="mac-product-grid">
      <!-- Cột Trái: Ảnh sản phẩm (Gallery) -->
      <div class="mac-product-media product__media-wrapper">
        {% assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src' %}
        {% render 'product-media-gallery', variant_images: variant_images %}
      </div>

      <!-- Cột Phải: Thông tin sản phẩm -->
      <div class="mac-product-info grid__item">
        <product-info
          id="ProductInfo-{{ section.id }}"
          data-section="{{ section.id }}"
          data-url="{{ product.url }}"
        >
          {%- assign product_form_id = 'product-form-' | append: section.id -%}
          
          <!-- Title -->
          <h1 class="mac-product-title">{{ product.title | escape }}</h1>

          <!-- Review Summary -->
          <div class="mac-review-summary">
            <div class="mac-stars">
              <svg viewBox="0 0 24 24" fill="#ed5b24" width="20" height="20"><path d="M12 17.27l-5.18 3.73 1.64-7.03L3 9.24l7.19-.61L12 2l1.81 6.63 7.19.61-5.46 4.73 1.64 7.03z"/></svg>
              <svg viewBox="0 0 24 24" fill="#ed5b24" width="20" height="20"><path d="M12 17.27l-5.18 3.73 1.64-7.03L3 9.24l7.19-.61L12 2l1.81 6.63 7.19.61-5.46 4.73 1.64 7.03z"/></svg>
              <svg viewBox="0 0 24 24" fill="#ed5b24" width="20" height="20"><path d="M12 17.27l-5.18 3.73 1.64-7.03L3 9.24l7.19-.61L12 2l1.81 6.63 7.19.61-5.46 4.73 1.64 7.03z"/></svg>
              <svg viewBox="0 0 24 24" fill="#ed5b24" width="20" height="20"><path d="M12 17.27l-5.18 3.73 1.64-7.03L3 9.24l7.19-.61L12 2l1.81 6.63 7.19.61-5.46 4.73 1.64 7.03z"/></svg>
              <svg viewBox="0 0 24 24" fill="#ed5b24" width="20" height="20"><path d="M12 17.27l-5.18 3.73 1.64-7.03L3 9.24l7.19-.61L12 2l1.81 6.63 7.19.61-5.46 4.73 1.64 7.03z"/></svg>
            </div>
            <a href="#reviews" class="mac-review-link">11 reviews</a>
          </div>
          <div
            class="mac-bought-past-month"
            data-product-id="{{ product.id }}"
            data-min-count="497"
            data-max-count="10000"
          >
            6K+ bought in past month
          </div>

          <!-- Price -->
          <div class="mac-price-wrapper" id="price-{{ section.id }}">
            <span class="mac-price-regular">{{ product.selected_or_first_available_variant.price | money_with_currency }}</span>
            {% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}
              <span class="mac-price-compare">{{ product.selected_or_first_available_variant.compare_at_price | money_with_currency }}</span>
              {% assign saving = product.selected_or_first_available_variant.compare_at_price | minus: product.selected_or_first_available_variant.price | times: 100.0 | divided_by: product.selected_or_first_available_variant.compare_at_price | round %}
              <span class="mac-price-save-badge">Save {{ saving }}%</span>
            {% endif %}
          </div>

          <!-- Delivery -->
          <div class="mac-delivery-block">
             <div class="mac-deliver-item">
               <span
                 class="mac-flag mac-country-flag"
                 data-fallback-country-iso="{{ localization.country.iso_code | escape }}"
                 aria-hidden="true"
               >
                 {{ localization.country | image_url: width: 20 | image_tag }}
               </span>
               <span>
                 Deliver to
                 <span
                   class="mac-country-name"
                   data-fallback-country-name="{{ localization.country.name | escape }}"
                 >
                   {{ localization.country.name }}
                 </span>
               </span>
             </div>
             <div class="mac-deliver-item">
               <span class="mac-truck">🚚</span>
               <span>Get it by: <strong>{{ delivery_window }}</strong></span>
             </div>
          </div>

          <!-- Hiển thị Variants động từ Shopify dạng Radio Button (Pill) -->
          {%- unless product.has_only_default_variant -%}
            <variant-selects
              id="variant-selects-{{ section.id }}"
              data-section="{{ section.id }}"
              data-url="{{ product.url }}"
            >
              {%- for option in product.options_with_values -%}
                <fieldset class="js product-form__input product-form__input--pill">
                  <legend class="form__label">{{ option.name }}</legend>
                  {% render 'product-variant-options',
                    product: product,
                    option: option,
                    block: section,
                    picker_type: 'button'
                  %}
                </fieldset>
              {%- endfor -%}
              <script type="application/json" data-selected-variant>
                {{ product.selected_or_first_available_variant | json }}
              </script>
            </variant-selects>
          {%- endunless -%}

          <!-- Box chứa nút Add to Cart -->
          <div class="mac-buy-buttons" style="margin-top: 20px;">
            {%- form 'product', product, id: product_form_id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
              <input 
                type="hidden" 
                name="id" 
                value="{{ product.selected_or_first_available_variant.id }}"
                {%- if product.selected_or_first_available_variant.available == false -%}
                  disabled
                {%- endif -%}
                class="product-variant-id"
              >

              <button type="submit" name="add" class="mac-btn-add" id="ProductSubmitButton-{{ section.id }}" {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}>
                <span class="text">
                  {% if product.selected_or_first_available_variant.available %}
                    ADD TO CART
                  {% else %}
                    SOLD OUT
                  {% endif %}
                </span>
                <div class="loading-overlay__spinner hidden">
                  <svg aria-hidden="true" focusable="false" class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg">
                    <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                  </svg>
                </div>
              </button>
            {%- endform -%}
          </div>

          <!-- Box chứa Accordion (Expanse) -->
          <div class="mac-product-accordions" style="margin-top: 2rem;">
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when 'collapsible_tab' -%}
                  <div class="product__accordion accordion quick-add-hidden" {{ block.shopify_attributes }}>
                    <details id="Details-{{ block.id }}-{{ section.id }}">
                      <summary>
                        <div class="summary__title">
                          <h2 class="h4 accordion__title inline-richtext">
                            {{ block.settings.heading | default: block.settings.page.title }}
                          </h2>
                        </div>
                        <svg aria-hidden="true" focusable="false" class="icon icon-caret" viewBox="0 0 10 6">
                          <path fill-rule="evenodd" clip-rule="evenodd" d="M9.354.646a.5.5 0 00-.708 0L5 4.293 1.354.646a.5.5 0 00-.708.708l4 4a.5.5 0 00.708 0l4-4a.5.5 0 000-.708z" fill="currentColor"></path>
                        </svg>
                      </summary>
                      <div class="accordion__content rte" id="ProductAccordion-{{ block.id }}-{{ section.id }}">
                        {%- if block.settings.heading == 'Description' or block.settings.heading == 'Mô tả' -%}
                          {{ product.description }}
                        {%- else -%}
                          {{ block.settings.content }}
                          {{ block.settings.page.content }}
                        {%- endif -%}
                      </div>
                    </details>
                  </div>
              {%- endcase -%}
            {%- endfor -%}
          </div>

          <!-- Thông báo đang có người xem / trong giỏ hàng -->
          <div class="mac-cart-watching" style="display: flex; align-items: center; gap: 8px; margin-top: 15px; color: #d32f2f; font-weight: 600; font-size: 1.4rem;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
              <circle cx="12" cy="12" r="3"></circle>
            </svg>
            <span><span class="random-cart-number">3</span> people have this item in their carts right now.</span>
          </div>

          <script>
            const initializeMacornerSocialProof = () => {
              const sectionRoot = document.getElementById('MainProduct-{{ section.id }}');
              if (!sectionRoot) return;

              const numSpan = sectionRoot.querySelector('.random-cart-number');
              if(numSpan) {
                numSpan.innerText = Math.floor(Math.random() * 7) + 2;
              }

              const boughtEl = sectionRoot.querySelector('.mac-bought-past-month');
              if (!boughtEl) return;

              const productId = boughtEl.dataset.productId;
              const minCount = Number.parseInt(boughtEl.dataset.minCount || '497', 10);
              const maxCount = Number.parseInt(boughtEl.dataset.maxCount || '10000', 10);
              const storageKey = `dekor365-bought-past-month-${productId}`;

              const getCookie = (name) => {
                const cookieString = `; ${document.cookie}`;
                const parts = cookieString.split(`; ${name}=`);
                if (parts.length !== 2) return null;
                return parts.pop().split(';').shift();
              };

              const setCookie = (name, value, days) => {
                const expiresAt = new Date(Date.now() + days * 24 * 60 * 60 * 1000).toUTCString();
                document.cookie = `${name}=${value}; expires=${expiresAt}; path=/; SameSite=Lax`;
              };

              const normalizeStoredValue = (value) => {
                const parsed = Number.parseInt(value || '', 10);
                if (Number.isNaN(parsed) || parsed < minCount || parsed > maxCount) return null;
                return parsed;
              };

              const formatBoughtCount = (count) => {
                if (count >= 1000) {
                  const shortValue = (count / 1000).toFixed(count >= 10000 ? 0 : 1).replace(/\.0$/, '');
                  return `${shortValue}K+`;
                }

                return `${count}+`;
              };

              let boughtCount = null;

              try {
                boughtCount = normalizeStoredValue(window.localStorage.getItem(storageKey));
              } catch (error) {
                boughtCount = null;
              }

              if (!boughtCount) {
                boughtCount = normalizeStoredValue(getCookie(storageKey));
              }

              if (!boughtCount) {
                boughtCount = Math.floor(Math.random() * (maxCount - minCount + 1)) + minCount;
              }

              boughtEl.textContent = `${formatBoughtCount(boughtCount)} bought in past month`;

              try {
                window.localStorage.setItem(storageKey, String(boughtCount));
              } catch (error) {
                // Fall back to cookie only when localStorage is unavailable.
              }

              setCookie(storageKey, String(boughtCount), 30);
            };

            if (document.readyState === 'loading') {
              document.addEventListener('DOMContentLoaded', initializeMacornerSocialProof, { once: true });
            } else {
              initializeMacornerSocialProof();
            }
          </script>

          <script>
            (() => {
              const sectionRoot = document.getElementById('MainProduct-{{ section.id }}');

              if (!sectionRoot) return;

              const countryNameEl = sectionRoot.querySelector('.mac-country-name');
              const countryFlagEl = sectionRoot.querySelector('.mac-country-flag');

              if (!countryNameEl || !countryFlagEl) return;

              const flagFromIso = (isoCode) => {
                if (!isoCode || isoCode.length !== 2) return '';

                return String.fromCodePoint(
                  ...isoCode
                    .toUpperCase()
                    .split('')
                    .map((char) => 127397 + char.charCodeAt(0))
                );
              };

              const resolveCountryName = (isoCode) => {
                try {
                  if (typeof Intl !== 'undefined' && typeof Intl.DisplayNames === 'function') {
                    const displayNames = new Intl.DisplayNames(
                      [document.documentElement.lang || 'en'],
                      { type: 'region' }
                    );
                    return displayNames.of(isoCode);
                  }
                } catch (error) {
                  return null;
                }

                return null;
              };

              const updateCountryDisplay = (regionCode) => {
                const isoCode = (regionCode || '').slice(0, 2).toUpperCase();
                if (!isoCode) return;

                const countryName = resolveCountryName(isoCode);
                if (countryName) {
                  countryNameEl.textContent = countryName;
                }

                const flag = flagFromIso(isoCode);
                if (flag) {
                  countryFlagEl.textContent = flag;
                }
              };

              const loadCustomerPrivacyRegion = () => {
                if (!(window.Shopify && typeof window.Shopify.loadFeatures === 'function')) return;

                window.Shopify.loadFeatures(
                  [{ name: 'consent-tracking-api', version: '0.1' }],
                  (error) => {
                    if (error || !(window.Shopify.customerPrivacy && window.Shopify.customerPrivacy.getRegion)) {
                      return;
                    }

                    updateCountryDisplay(window.Shopify.customerPrivacy.getRegion());
                  }
                );
              };

              loadCustomerPrivacyRegion();
            })();
          </script>

        </product-info>
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Macorner Clean Product",
  "settings": [
    {
      "type": "header",
      "content": "Delivery estimate"
    },
    {
      "type": "paragraph",
      "content": "Set the default shipping window here, then add Shipping rule blocks below for product-tag-specific delivery ranges. The first matching tag wins."
    },
    {
      "type": "range",
      "id": "default_shipping_min_days",
      "min": 1,
      "max": 30,
      "step": 1,
      "default": 5,
      "label": "Default minimum shipping days"
    },
    {
      "type": "range",
      "id": "default_shipping_max_days",
      "min": 1,
      "max": 30,
      "step": 1,
      "default": 8,
      "label": "Default maximum shipping days"
    },
    {
      "type": "select",
      "id": "picker_type",
      "options": [
        {
          "value": "dropdown",
          "label": "Dropdown"
        },
        {
          "value": "button",
          "label": "Pill"
        }
      ],
      "default": "button",
      "label": "Variant picker type"
    },
    {
      "type": "select",
      "id": "gallery_layout",
      "options": [
        {
          "value": "stacked",
          "label": "Stacked"
        },
        {
          "value": "thumbnail_slider",
          "label": "Thumbnail slider"
        }
      ],
      "default": "thumbnail_slider",
      "label": "Media Gallery Layout"
    },
    {
      "type": "select",
      "id": "media_size",
      "options": [
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "large",
          "label": "Large"
        }
      ],
      "default": "large",
      "label": "Media Size"
    },
    {
      "type": "select",
      "id": "media_position",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left",
      "label": "Media Position"
    },
    {
      "type": "select",
      "id": "mobile_thumbnails",
      "options": [
        {
          "value": "show",
          "label": "Show"
        },
        {
          "value": "hide",
          "label": "Hide"
        },
        {
          "value": "columns",
          "label": "Columns"
        }
      ],
      "default": "show",
      "label": "Mobile Thumbnails"
    }
  ],
  "blocks": [
    {
      "type": "shipping_rule",
      "name": "Shipping rule",
      "settings": [
        {
          "type": "text",
          "id": "product_tag",
          "label": "Product tag",
          "info": "Exact product tag to match, for example: shirt"
        },
        {
          "type": "range",
          "id": "min_days",
          "min": 1,
          "max": 30,
          "step": 1,
          "default": 5,
          "label": "Minimum shipping days"
        },
        {
          "type": "range",
          "id": "max_days",
          "min": 1,
          "max": 30,
          "step": 1,
          "default": 8,
          "label": "Maximum shipping days"
        }
      ]
    },
    {
      "type": "collapsible_tab",
      "name": "Collapsible row",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Collapsible row",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Row content"
        },
        {
          "type": "page",
          "id": "page",
          "label": "Row content from page"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Macorner Clean Product"
    }
  ]
}
{% endschema %}
