<style>
.footer-dekor {
  background-color: var(--bg-color-main, #f8f8f8);
  padding: 60px 0 20px;
  color: #333;
  position: relative;
  border-top: 1px solid #eaeaea;
}
.footer-dekor-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 30px;
  margin-bottom: 40px;
}
.footer-col-title {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 20px;
  text-transform: uppercase;
}
.footer-col-info p {
  font-size: 14px;
  line-height: 1.6;
  margin-bottom: 10px;
}
.footer-dekor-menu {
  list-style: none;
  padding: 0;
  margin: 0;
}
.footer-dekor-menu li {
  margin-bottom: 12px;
}
.footer-dekor-menu a {
  text-decoration: none;
  color: #555;
  font-size: 14px;
  transition: color 0.3s;
}
.footer-dekor-menu a:hover {
  color: var(--color-primary-dekor);
}
.footer-socials {
  display: flex;
  gap: 15px;
  margin-top: 20px;
}
.footer-socials a {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: #eee;
  color: #333;
  transition: all 0.3s;
}
.footer-socials a:hover {
  background: var(--color-primary-dekor);
  color: #fff;
}
.footer-dekor-bottom {
  border-top: 1px solid #ddd;
  padding-top: 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 15px;
}
.footer-copyright {
  font-size: 13px;
  color: #666;
}
.footer-badges {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  justify-content: center;
}
.footer-badges img {
  height: 25px;
  width: auto;
}
.scroll-to-top {
  position: fixed;
  bottom: 30px;
  right: 30px;
  width: 45px;
  height: 45px;
  background-color: var(--color-primary-dekor);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  text-decoration: none;
  cursor: pointer;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s, visibility 0.3s;
  z-index: 999;
  box-shadow: 0 4px 10px rgba(0,0,0,0.1);
}
.scroll-to-top.visible {
  opacity: 1;
  visibility: visible;
}
.scroll-to-top:hover {
  background-color: var(--color-primary-dekor-hover);
  color: white;
}

@media (max-width: 990px) {
  .footer-dekor-grid {
    grid-template-columns: 1fr 1fr;
  }
}

@media (max-width: 750px) {
  .footer-dekor-grid {
    grid-template-columns: 1fr;
    text-align: center;
  }
  .footer-socials {
    justify-content: center;
  }
  .scroll-to-top {
    bottom: 20px;
    right: 20px;
  }
}
</style>

<footer class="footer-dekor">
  <div class="page-width">
    <div class="footer-dekor-grid">
      <!-- Column 1: Info -->
      <div class="footer-col footer-col-info">
        <h3 class="footer-col-title">About Us</h3>
        {%- if settings.logo != blank -%}
          <img src="{{ settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" style="max-height: 40px; margin-bottom: 15px;">
        {%- else -%}
          <img src="https://cdn.shopify.com/s/files/1/0617/6325/6561/files/d5_fcfc668b-b8fe-4eeb-b684-2ca9991ca9fd_225x.png" alt="Dekor365" style="max-height: 40px; margin-bottom: 15px;">
        {%- endif -%}
        <p><strong>Email:</strong> support@365dekor.com</p>
        <p><strong>Business Hours:</strong> Monday - Friday, 9am - 5pm EST</p>
        <div class="footer-socials">
          <a href="#" aria-label="Facebook"><svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg></a>
          <a href="#" aria-label="Instagram"><svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg></a>
          <a href="#" aria-label="TikTok"><svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path></svg></a>
        </div>
      </div>

      <!-- Column 2: Link 1 -->
      <div class="footer-col">
        <h3 class="footer-col-title">Shop</h3>
        <ul class="footer-dekor-menu">
          {%- if section.settings.menu_1 != blank -%}
            {%- for link in linklists[section.settings.menu_1].links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          {%- else -%}
            <li><a href="/collections/all">All Products</a></li>
            <li><a href="/collections/new-arrivals">New Arrivals</a></li>
            <li><a href="/collections/best-sellers">Best Sellers</a></li>
          {%- endif -%}
        </ul>
      </div>

      <!-- Column 3: Link 2 -->
      <div class="footer-col">
        <h3 class="footer-col-title">Support</h3>
        <ul class="footer-dekor-menu">
          {%- if section.settings.menu_2 != blank -%}
            {%- for link in linklists[section.settings.menu_2].links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          {%- else -%}
            <li><a href="/pages/faq">FAQs</a></li>
            <li><a href="/pages/track-order">Track Order</a></li>
            <li><a href="/pages/contact">Contact Us</a></li>
          {%- endif -%}
        </ul>
      </div>

      <!-- Column 4: Link 3 -->
      <div class="footer-col">
        <h3 class="footer-col-title">Policies</h3>
        <ul class="footer-dekor-menu">
          {%- if section.settings.menu_3 != blank -%}
            {%- for link in linklists[section.settings.menu_3].links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          {%- else -%}
            <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
            <li><a href="/policies/terms-of-service">Terms of Service</a></li>
            <li><a href="/policies/refund-policy">Return Policy</a></li>
            <li><a href="/policies/shipping-policy">Shipping Policy</a></li>
          {%- endif -%}
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="footer-dekor-bottom">
      <div class="footer-badges">
        <img src="https://cdn.shopify.com/s/assets/payment_icons/visa-319d545c6fd255c9aad5eeaad21fd6f7f7b4fdbdb1a35ce83b89cca12a187f00.svg" alt="Visa" width="38" height="24">
        <img src="https://cdn.shopify.com/s/assets/payment_icons/master-173035bc8124581983d4efa50cf8626e8553c2b311353fbf67485f9c1a2b88d1.svg" alt="Mastercard" width="38" height="24">
        <img src="https://cdn.shopify.com/s/assets/payment_icons/american_express-2264c9b8b57b23b0b0831827e90cd7bcda2836adc42a912ebedf545dead35b20.svg" alt="Amex" width="38" height="24">
        <img src="https://cdn.shopify.com/s/assets/payment_icons/discover-cc9808e50193c7496e7a5245eb86d5e06f02e2476c0fe70f2c40016707d35461.svg" alt="Discover" width="38" height="24">
        <img src="https://cdn.shopify.com/s/assets/payment_icons/paypal-49e4c1e03244b6d2de0d270cb0d220522204cb428ce0a192c5949eea385ce120.svg" alt="PayPal" width="38" height="24">
        <!-- DMCA Badge -->
        <img src="https://images.dmca.com/Badges/_dmca_premi_badge_4.png?ID=b5514f7b-6d8b-4b14-8b6l-20c2b2a609d7" alt="DMCA.com Protection Status" style="margin-left:10px;">
      </div>
      <div class="footer-copyright">
        © 365dekor All Rights Reserved.
      </div>
    </div>
  </div>
</footer>

<!-- Scroll to Top Button -->
<button id="scrollToTopBtn" class="scroll-to-top" aria-label="Scroll to top" title="Scroll to top">
  <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"></polyline></svg>
</button>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var scrollToTopBtn = document.getElementById('scrollToTopBtn');
    
    window.addEventListener('scroll', function() {
      if (window.pageYOffset > 300) {
        scrollToTopBtn.classList.add('visible');
      } else {
        scrollToTopBtn.classList.remove('visible');
      }
    });

    scrollToTopBtn.addEventListener('click', function(e) {
      e.preventDefault();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });
</script>

{% schema %}
{
  "name": "Chân trang (Footer)",
  "settings": [
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "Menu Cột 2 (Shop)"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "Menu Cột 3 (Support)"
    },
    {
      "type": "link_list",
      "id": "menu_3",
      "label": "Menu Cột 4 (Policies)"
    }
  ]
}
{% endschema %}
