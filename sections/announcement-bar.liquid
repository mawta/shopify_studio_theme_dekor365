{%- comment -%} Section: Announcement Bar - Thanh thông báo phong cách Macorner {%- endcomment -%}

<style>
.announcement-bar-live {
  background: {{ section.settings.bg_color | default: '#F36621' }};
  text-align: center;
  padding: 10px 0;
  font-size: 15px;
  font-weight: 600;
  color: {{ section.settings.text_color | default: '#ffffff' }};
  margin: 0;
  border-bottom: none;
  letter-spacing: 0.02em;
}
.announcement-bar-live a {
  color: {{ section.settings.text_color | default: '#ffffff' }};
  text-decoration: underline;
}
</style>

<div class="announcement-bar-live">
  {{ section.settings.text }}
</div>

{% schema %}
{
  "name": "Thanh thông báo",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Văn bản thông báo",
      "default": "Buy 2+, Save 10% | Code: MSW2"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Màu nền",
      "default": "#F36621"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Màu chữ",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Thanh thông báo"
    }
  ]
}
{% endschema %}

