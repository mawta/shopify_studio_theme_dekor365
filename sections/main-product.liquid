<script>
document.addEventListener("DOMContentLoaded", function() {
    // Dùng interval để chờ App Customily render xong DOM
    const checkExist = setInterval(function() {
        
        // 1. targetEl: Phần tử thực tế ta sẽ cho trượt lơ lửng
        const targetEl = document.querySelector('.canvas-wrapper'); 
        
        // 2. anchorEl: Khung gốc chứa canvas (Dùng làm "mỏ neo" để đo tọa độ chuẩn)
        const anchorEl = document.querySelector('.cl-canvas-container'); 
        
        // 3. boundaryEl: Toàn bộ cột media bên trái (Đuôi của cái này là vạch đích)
        const boundaryEl = document.querySelector('.product__media-wrapper');

        if (targetEl && anchorEl && boundaryEl) {
            clearInterval(checkExist);
            initSmartSticky(targetEl, anchorEl, boundaryEl);
        }
    }, 500);

    function initSmartSticky(target, anchor, boundary) {
        // Khoảng cách từ đỉnh màn hình xuống canvas khi đang trượt (đại kaaa chỉnh lại nếu vướng Header)
        const stickyTopOffset = 50; 

        function onScroll() {
            const boundaryRect = boundary.getBoundingClientRect();
            const anchorRect = anchor.getBoundingClientRect();
            const targetHeight = target.offsetHeight; // Lấy chiều cao thực của canvas

            // TRẠNG THÁI 1: Khi chưa cuộn tới ảnh (hoặc cuộn ngược lên trên)
            if (anchorRect.top > stickyTopOffset) {
                target.style.setProperty('position', 'relative', 'important');
                target.style.setProperty('top', '0px', 'important');
                target.style.setProperty('left', '0px', 'important');
                target.style.setProperty('width', '100%', 'important');
            }
            // TRẠNG THÁI 2 & 3: Bắt đầu cuộn qua ảnh
            else {
                // Chuyển sang fixed để "bay" tự do, vô hiệu hóa mọi CSS cản trở của thẻ cha
                target.style.setProperty('position', 'fixed', 'important');
                target.style.setProperty('left', anchorRect.left + 'px', 'important');
                target.style.setProperty('width', anchorRect.width + 'px', 'important');
                target.style.setProperty('z-index', '9999', 'important'); // Nổi lên trên cùng

                // ===== LOGIC QUYẾT ĐỊNH: ĐUÔI CHẠM ĐUÔI =====
                const maxBottom = boundaryRect.bottom; // Tọa độ Y đáy của toàn bộ cột trái
                const predictedBottom = stickyTopOffset + targetHeight; // Tọa độ Y đáy của canvas nếu đang bay

                // Nếu đáy của canvas chạm/vượt quá đáy của cột trái -> Thắng gấp!
                if (predictedBottom > maxBottom) {
                    const pushUpTop = maxBottom - targetHeight; 
                    target.style.setProperty('top', pushUpTop + 'px', 'important');
                } 
                // Nếu chưa chạm đáy cột trái -> Tiếp tục bay lơ lửng ở offset
                else {
                    target.style.setProperty('top', stickyTopOffset + 'px', 'important');
                }
            }
        }

        // Lắng nghe cuộn và resize màn hình
        window.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('resize', onScroll);
        onScroll(); // Tính toán ngay lúc vừa load xong

        // ===== OBSERVER: CHỐNG LẠI APP BÊN THỨ 3 =====
        // Nếu app Customily cố tình chèn lại style cũ, Observer sẽ vả lại ngay lập tức
        const observer = new MutationObserver((mutations) => {
            let needFix = false;
            mutations.forEach(m => {
                if (m.attributeName === 'style') {
                    const currentPos = target.style.position;
                    // Nếu bị mất thuộc tính fixed hoặc relative mà mình đã set
                    if (currentPos !== 'fixed' && currentPos !== 'relative') {
                        needFix = true;
                    }
                }
            });
            if (needFix) onScroll(); // Bắt tính toán lại vị trí ngay
        });
        
        observer.observe(target, { attributes: true, attributeFilter: ['style'] });
    }
});
