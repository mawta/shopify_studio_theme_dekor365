        // TRẠNG THÁI: DESKTOP STICKY
        const stickyTopOffset = 50; 
        const boundaryRect = boundary.getBoundingClientRect();
        const anchorRect = anchor.getBoundingClientRect();
        const targetHeight = target.offsetHeight; 

        target.style.setProperty('margin', '0', 'important');

        // Khi chưa cuộn tới
        if (anchorRect.top > stickyTopOffset) {
            target.style.setProperty('position', 'relative', 'important');
            target.style.setProperty('top', '0px', 'important');
            target.style.setProperty('left', '0px', 'important');
            target.style.setProperty('width', '100%', 'important');
            forceCenterContent(); 
        } 
        // Khi bắt đầu cuộn
        else {
            target.style.setProperty('position', 'fixed', 'important');
            target.style.setProperty('left', anchorRect.left + 'px', 'important');
            target.style.setProperty('width', anchorRect.width + 'px', 'important');
            target.style.setProperty('z-index', '9999', 'important');
            forceCenterContent(); 

            const maxBottom = boundaryRect.bottom; 
            const predictedBottom = stickyTopOffset + targetHeight; 

            if (predictedBottom > maxBottom) {
                const pushUpTop = maxBottom - targetHeight; 
                target.style.setProperty('top', pushUpTop + 'px', 'important');
            } else {
                target.style.setProperty('top', stickyTopOffset + 'px', 'important');
            }
        }
    };

    // === QUẢN LÝ OBSERVER VÀ SCROLL CHỐNG GIẬT ===
    const galleryTarget = document.querySelector('media-gallery') || document.body;
    const observerConfig = { childList: true, subtree: true, attributes: true, attributeFilter: ['style', 'class'] };

    const globalObserver = new MutationObserver((mutations) => {
        globalObserver.disconnect(); 
        syncCanvasToMedia();
        updateStickyPosition(); 
        globalObserver.observe(galleryTarget, observerConfig); 
    });

    const onScroll = () => {
        if (!isTicking) {
            window.requestAnimationFrame(() => {
                globalObserver.disconnect(); 
                updateStickyPosition();
                globalObserver.observe(galleryTarget, observerConfig); 
                isTicking = false;
            });
            isTicking = true;
        }
    };

    // === KHỞI CHẠY KHUNG GIAO DIỆN ===
    syncCanvasToMedia();
    updateStickyPosition();
    
    if (galleryTarget) {
        globalObserver.observe(galleryTarget, observerConfig);
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', () => {
        globalObserver.disconnect(); 
        updateStickyPosition();
        globalObserver.observe(galleryTarget, observerConfig); 
    });
    
    const checkExist = setInterval(function() {
        if (document.querySelector('.canvas-wrapper') && document.querySelector('.cl-canvas-container')) {
            updateStickyPosition();
            clearInterval(checkExist);
        }
    }, 500);
});
</script>

