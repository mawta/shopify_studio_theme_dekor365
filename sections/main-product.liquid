        const boundary = document.querySelector('.product__media-wrapper');

        if (!target || !anchor || !boundary) return;

        // [QUAN TRỌNG] Hàm ép wrapper làm flex container để luôn căn giữa lõi 352px
        const forceCenterContent = () => {
            target.style.setProperty('display', 'flex', 'important');
            target.style.setProperty('justify-content', 'center', 'important');
        };

        const previewModal = document.getElementById('preview-container');
        const isInsideModal = target.closest('#preview-container') !== null;
        const isModalOpen = previewModal && window.getComputedStyle(previewModal).display !== 'none';
        
        const isMobile = window.innerWidth < 768; 

        // TRẠNG THÁI: MOBILE HOẶC ĐANG MỞ PREVIEW (Không Sticky, Ép Căn Giữa)
        if (isInsideModal || isModalOpen || isMobile) {
            target.style.setProperty('position', 'relative', 'important');
            target.style.setProperty('top', '0px', 'important');
            target.style.setProperty('left', 'auto', 'important'); 
            target.style.setProperty('margin', '0 auto', 'important'); 
            target.style.setProperty('width', '100%', 'important');
            target.style.setProperty('z-index', '10', 'important');
            
            forceCenterContent(); // <-- CHÌA KHÓA TRỊ BỆNH LỆCH TRÁI
