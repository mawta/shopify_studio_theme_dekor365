<script>
document.addEventListener('DOMContentLoaded', function() {
    let isTicking = false;
    
    // === HÀM 1: ĐỒNG BỘ HIỂN THỊ CANVAS (ẨN ẢNH GỐC) ===
    const syncCanvasToMedia = () => {
        const canvasContainers = document.querySelectorAll('.cl-canvas-container');
        canvasContainers.forEach((canvas) => {
            const parentSlide = canvas.closest('.product__media-item');
            if (!parentSlide) return;

            const mediaContainer = parentSlide.querySelector('.product-media-container');
            if (!mediaContainer) return;

            mediaContainer.style.setProperty('background-color', '#ffffff', 'important');
            mediaContainer.style.setProperty('position', 'relative', 'important');

            const originalMedia = mediaContainer.querySelector('.product__media.media');
            if (originalMedia) {
                originalMedia.style.setProperty('display', 'none', 'important');
            }

            canvas.style.setProperty('position', 'absolute', 'important');
            canvas.style.setProperty('top', '0', 'important');
            canvas.style.setProperty('left', '0', 'important');
            canvas.style.setProperty('width', '100%', 'important');
            canvas.style.setProperty('height', '100%', 'important');
            canvas.style.setProperty('margin', '0', 'important');
            canvas.style.setProperty('z-index', '10', 'important');
            canvas.style.setProperty('background-color', '#ffffff', 'important');

            canvas.style.setProperty('display', 'flex', 'important');
            canvas.style.setProperty('justify-content', 'center', 'important'); 
            canvas.style.setProperty('align-items', 'center', 'important');

            const uiElements = parentSlide.querySelectorAll('.product__media-icon, .product__media-toggle');
            uiElements.forEach(el => el.style.setProperty('display', 'none', 'important'));
        });
    };

    // === HÀM 2: TÍNH TOÁN STICKY & FIX LỆCH ===
    const updateStickyPosition = () => {
        const target = document.querySelector('.canvas-wrapper'); 
