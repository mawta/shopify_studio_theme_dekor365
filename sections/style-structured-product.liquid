{% style %}
    .wood-swatch{
      background: linear-gradient(135deg, #7b4b2a, #d6b28e) !important;
    }
    .hippie-swatch label {
      background: linear-gradient(135deg, #ff8a65, #ffd180, #81c784);
    }
    .graphite-swatch{
      background: #50545c !important;
    }
    .moss-swatch{
      background: #7b7f57 !important;
    }
    .yam-swatch{
      background: #bc6c4a !important;
    } 
    .pepper-swatch  {
      background: #6b4c3b !important;
    }
    .orchid-swatch  {
      background: #b082b5 !important;
    }
    .light-green-swatch  {
      background: #b8c8a0 !important;
    }
    .ivory-swatch  {
      background: #f2ead9 !important;
    }
    .blue-jean-swatch  {
      background: #607d8b !important;
    }
    .wood-swatch,
    .hippie-swatch label,
    .graphite-swatch,
    .moss-swatch,
    .yam-swatch,
    .pepper-swatch,
    .orchid-swatch,
    .light-green-swatch,
    .ivory-swatch,
    .blue-jean-swatch {
      background-position: center;
      background-repeat: no-repeat;
      background-size: cover;
    }
{% endstyle %}
  
