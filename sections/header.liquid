<style>
.header-dekor {
  background: #ffffff;
}

.header-dekor-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px 0;
}

.header-dekor-logo img {
  max-height: 45px;
  width: auto;
  display: block;
}

.header-dekor-logo a {
  text-decoration: none;
  color: #333;
}

.header-dekor-search {
  flex: 1;
  max-width: 600px;
  margin: 0 40px;
}

.header-dekor-search form {
  display: flex;
  background: #fafafa;
  border-radius: 30px;
  padding: 2px 20px;
  align-items: center;
  border: 1px solid #ddd;
}

.header-dekor-search input {
  border: none;
  background: transparent;
  flex: 1;
  padding: 12px 0;
  outline: none;
  font-size: 15px;
  color: #333;
}

.header-dekor-icons {
  display: flex;
  align-items: center;
  gap: 25px;
  font-size: 14px;
}

.header-dekor-icons a, .header-dekor-icons .utility-item {
  color: #333;
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 5px;
}

.header-icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 13px;
}

.header-icon-item svg {
  width: 20px;
  height: 20px;
  margin-bottom: 3px;
  stroke: #333;
}

/* Bottom Menu */
.header-dekor-bottom {
  display: flex;
  justify-content: center;
  padding: 15px 0;
}

.header-dekor-border-wrap {
  border-bottom: 1px solid #333; /* Live site has a thin dark border separating header and content */
  padding-bottom: 15px;
}

.header-dekor-menu {
  display: flex;
  gap: 40px;
  list-style: none;
  margin: 0;
  padding: 0;
}

.header-dekor-menu a {
  text-decoration: none;
  color: #333;
  font-weight: 500;
  font-size: 15px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.header-dekor-menu a:hover {
  color: var(--color-primary-dekor);
}

@media (max-width: 768px) {
  .header-dekor-top { 
    flex-direction: column; 
    gap: 15px; 
    padding: 15px 0;
  }
  .header-dekor-search { 
    max-width: 100%; 
    margin: 0; 
    width: 100%; 
  }
  .header-dekor-icons {
    justify-content: space-between;
    width: 100%;
  }
  .header-dekor-menu {
    gap: 20px;
    flex-wrap: wrap;
    justify-content: center;
  }
}
</style>

<div class="header-dekor">
  <div class="page-width">
    <!-- Top Row -->
    <div class="header-dekor-top">
      <div class="header-dekor-logo">
        <a href="{{ routes.root_url }}">
          {%- if settings.logo != blank -%}
            <img src="{{ settings.logo | image_url: width: 400 }}" alt="{{ shop.name }}">
          {%- else -%}
            <img src="https://cdn.shopify.com/s/files/1/0617/6325/6561/files/d5_fcfc668b-b8fe-4eeb-b684-2ca9991ca9fd_225x.png" alt="Dekor365">
          {%- endif -%}
        </a>
      </div>

      <div class="header-dekor-search">
        <form action="{{ routes.search_url }}" method="get" role="search">
          <input type="text" name="q" placeholder="Search" value="{{ search.terms | escape }}">
          <button type="submit" style="background:transparent!important; color:#333!important; border:none!important; padding:0!important; cursor:pointer; box-shadow:none!important;">
            <svg viewBox="0 0 20 20" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="9" r="7"></circle><line x1="21" y1="21" x2="15" y2="15"></line></svg>
          </button>
        </form>
      </div>

      <div class="header-dekor-icons">
        <a href="/pages/track-order" class="utility-item">Track Order</a>
        <div class="utility-item" style="cursor: pointer;">
           <img src="https://upload.wikimedia.org/wikipedia/commons/2/21/Flag_of_Vietnam.svg" width="20" height="14" alt="VN" style="border-radius:2px;"> | USD ($)
        </div>
        <a href="{{ routes.account_login_url }}" class="header-icon-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
          <span>Login</span>
        </a>
        <a href="{{ routes.cart_url }}" class="header-icon-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1.5"></circle><circle cx="20" cy="21" r="1.5"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
          <span>Cart</span>
        </a>
      </div>
    </div>
    
    <!-- Bottom Row (Menu) -->
    <div class="header-dekor-border-wrap">
      <div class="header-dekor-bottom">
        <ul class="header-dekor-menu">
          {%- if section.settings.menu != blank -%}
            {% for link in linklists[section.settings.menu].links %}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
          {%- else -%}
            <li><a href="/">HOME</a></li>
            <li><a href="/collections/all">PRODUCT</a></li>
            <li><a href="/pages/track-order">TRACK ORDER</a></li>
          {%- endif -%}
        </ul>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Đầu trang (Header)",
  "class": "section-header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Menu (Trình đơn)"
    }
  ]
}
{% endschema %}
